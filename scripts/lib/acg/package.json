{
  "name": "lib-acg",
  "version": "0.4.0",
  "description": "ACG browser automation \u2014 Chrome CDP, Playwright, credential extraction",
  "private": true,
  "scripts": {
    "check": "node --check playwright/*.js playwright/lib/*.js playwright/providers/*.js",
    "test": "jest",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^29.7.0"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/providers/**/*.test.js"
    ]
  }
}
